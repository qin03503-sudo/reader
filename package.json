{
  "name": "app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "preview": "bun ./build/index.js",
    "start": "bun ./build/index.js",
    "prepare": "(bun --bun svelte-kit sync || true) && (sed -i 's/const websocket = server\\.websocket();/const websocket = typeof server.websocket === \"function\" ? server.websocket() : null;/' node_modules/svelte-adapter-bun/dist/files/handler.js 2>/dev/null || true)",
    "check": "bun --bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun --bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@google/genai": "^2.4.0",
    "@lucide/svelte": "^1.16.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jszip": "^3.10.1",
    "pg": "^8.20.0",
    "postgres": "^3.4.9",
    "svelte": "^5.55.7",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "terser": "^5.47.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-compression": "^0.5.1"
  }
}
